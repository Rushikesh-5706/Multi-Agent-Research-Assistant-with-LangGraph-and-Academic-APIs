# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Ollama LLM endpoint (set automatically by docker-compose)
OLLAMA_HOST=http://ollama:11434

# Optional: Semantic Scholar API key — improves rate limits but not required
# SEMANTIC_SCHOLAR_API_KEY=your_key_here

# Optional: Anthropic Claude API key — not used in default Ollama config
# ANTHROPIC_API_KEY=your_key_here
